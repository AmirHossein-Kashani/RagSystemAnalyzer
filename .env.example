# All settings are optional; defaults live in app/config.py.
# Override any of them by uncommenting and prefixing with RAG_.

# RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# RAG_CHUNK_SIZE=800
# RAG_CHUNK_OVERLAP=120
# RAG_DEFAULT_TOP_K=5
# RAG_DOCS_DIR=data/docs
# RAG_CHROMA_DIR=data/chroma
# RAG_COLLECTION_NAME=documents

# Google Drive sync (public folders only; server-side key — never expose to browser)
# RAG_GOOGLE_API_KEY=
# RAG_DRIVE_REQUEST_TIMEOUT_SECONDS=60
